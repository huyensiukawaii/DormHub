// =============================================
// DORMHUB - HỆ THỐNG QUẢN LÝ KÝ TÚC XÁ
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// ENUMS
// =============================================

enum UserRole {
  ADMIN
  STAFF
  STUDENT
}

enum Gender {
  MALE
  FEMALE
}

enum BuildingStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RoomType {
  STANDARD
  AIR_CONDITIONED
}

enum RoomStatus {
  ACTIVE
  MAINTENANCE
  CLOSED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum PeriodType {
  NEW_REGISTRATION
  RENEWAL
}

enum PeriodStatus {
  UPCOMING
  OPEN
  CLOSED
}

enum ApplicationType {
  NEW
  RENEWAL
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ContractStatus {
  ACTIVE
  TERMINATED
  EXPIRED
}

enum MeterType {
  ELECTRICITY
  WATER
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum TicketCategory {
  ELECTRICAL
  PLUMBING
  AIR_CONDITIONER
  DOOR_LOCK
  FURNITURE
  OTHER
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum TicketPriority {
  LOW
  NORMAL
  URGENT
}

// =============================================
// MODELS
// =============================================

// 1. User - Tài khoản người dùng
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  fullName     String   @map("full_name")
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student               Student?
  reviewedApplications  RegistrationApplication[] @relation("ReviewedBy")
  createdContracts      Contract[]                @relation("CreatedBy")
  passwordResetTokens   PasswordResetToken[]
  recordedMeterReadings MeterReading[]
  approvedInvoices      Invoice[]                 @relation("ApprovedBy")
  handledTickets        MaintenanceTicket[]       @relation("HandledBy")
  notifications         Notification[]
  updatedSettings       Setting[]

  @@map("users")
}

// 2. Building - Tòa nhà
model Building {
  id          Int            @id @default(autoincrement())
  code        String         @unique // A, B, C
  name        String
  totalFloors Int            @map("total_floors")
  description String?
  status      BuildingStatus @default(ACTIVE)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  rooms Room[]

  @@map("buildings")
}

// 3. Room - Phòng
model Room {
  id            Int        @id @default(autoincrement())
  code          String     @unique // A101, A102
  buildingId    Int        @map("building_id")
  floor         Int
  gender        Gender
  roomType      RoomType   @map("room_type")
  capacity      Int // Số giường
  pricePerMonth Decimal    @map("price_per_month") @db.Decimal(12, 0)
  description   String?
  status        RoomStatus @default(ACTIVE)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  building      Building            @relation(fields: [buildingId], references: [id])
  beds          Bed[]
  roomChoices   RoomChoice[]
  contracts     Contract[]
  meterReadings MeterReading[]
  invoices      Invoice[]
  tickets       MaintenanceTicket[]

  // Gia hạn: phòng hiện tại
  renewalApplications  RegistrationApplication[] @relation("CurrentRoom")
  approvedApplications RegistrationApplication[] @relation("ApprovedRoom")

  @@index([buildingId])
  @@index([status])
  @@map("rooms")
}

// 4. Bed - Giường
model Bed {
  id        Int       @id @default(autoincrement())
  code      String    @unique // A101-01, A101-02
  roomId    Int       @map("room_id")
  position  String? // Giường tầng trên/dưới, gần cửa sổ
  status    BedStatus @default(AVAILABLE)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  room      Room       @relation(fields: [roomId], references: [id])
  contracts Contract[]

  @@index([roomId])
  @@index([status])
  @@map("beds")
}

// 5. Student - Sinh viên
model Student {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique @map("user_id")
  studentCode      String    @unique @map("student_code") // MSSV
  fullName         String    @map("full_name")
  gender           Gender
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  idCardNumber     String?   @map("id_card_number") // CCCD
  phone            String?
  email            String?
  majorCode        String?   @map("major_code") // Mã ngành học
  faculty          String? // Khoa
  className        String?   @map("class_name") // Lớp
  hometownProvince String?   @map("hometown_province") // Tỉnh quê quán
  hometownDistance Int?      @map("hometown_distance") // Khoảng cách (km)

  emergencyContactName     String? @map("emergency_contact_name")
  emergencyContactPhone    String? @map("emergency_contact_phone")
  emergencyContactRelation String? @map("emergency_contact_relation")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User                      @relation(fields: [userId], references: [id])
  applications RegistrationApplication[]
  contracts    Contract[]
  tickets      MaintenanceTicket[]

  @@index([studentCode])
  @@map("students")
}

// 6. RegistrationPeriod - Đợt đăng ký
model RegistrationPeriod {
  id        Int          @id @default(autoincrement())
  name      String // "Đợt đăng ký KTX Kỳ 2025.2"
  semester  String // "2025.2"
  type      PeriodType // NEW_REGISTRATION / RENEWAL
  startDate DateTime     @map("start_date")
  endDate   DateTime     @map("end_date")
  status    PeriodStatus @default(UPCOMING)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  applications RegistrationApplication[]

  @@index([semester])
  @@index([status])
  @@map("registration_periods")
}

// 7. RegistrationApplication - Đơn đăng ký
model RegistrationApplication {
  id        Int             @id @default(autoincrement())
  studentId Int             @map("student_id")
  periodId  Int             @map("period_id")
  type      ApplicationType @default(NEW) // NEW / RENEWAL

  // Nếu gia hạn
  currentRoomId Int?    @map("current_room_id") // Phòng đang ở
  wantSameRoom  Boolean @default(true) @map("want_same_room") // Muốn ở phòng cũ?

  // Thông tin ưu tiên (chỉ áp dụng cho đăng ký mới)
  isFirstYear     Boolean  @default(false) @map("is_first_year")
  isPoorHousehold Boolean  @default(false) @map("is_poor_household")
  isNearPoor      Boolean  @default(false) @map("is_near_poor")
  isOrphan        Boolean  @default(false) @map("is_orphan")
  isDisabled      Boolean  @default(false) @map("is_disabled")
  isPolicyFamily  Boolean  @default(false) @map("is_policy_family")
  gpaLastSemester Decimal? @map("gpa_last_semester") @db.Decimal(3, 2)
  wasResident     Boolean  @default(false) @map("was_resident")

  priorityScore   Int   @default(0) @map("priority_score")
  priorityDetails Json? @map("priority_details")
  documents       Json? // URLs file upload

  // Kết quả duyệt
  status           ApplicationStatus @default(PENDING)
  approvedRoomId   Int?              @map("approved_room_id") // Phòng được duyệt
  approvedPriority Int?              @map("approved_priority") // Nguyện vọng mấy (1,2,3)
  reviewedById     Int?              @map("reviewed_by")
  reviewedAt       DateTime?         @map("reviewed_at")
  rejectionReason  String?           @map("rejection_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student      Student            @relation(fields: [studentId], references: [id])
  period       RegistrationPeriod @relation(fields: [periodId], references: [id])
  currentRoom  Room?              @relation("CurrentRoom", fields: [currentRoomId], references: [id])
  approvedRoom Room?              @relation("ApprovedRoom", fields: [approvedRoomId], references: [id])
  reviewedBy   User?              @relation("ReviewedBy", fields: [reviewedById], references: [id])
  roomChoices  RoomChoice[]
  contract     Contract?

  @@index([studentId])
  @@index([periodId])
  @@index([status])
  @@map("registration_applications")
}

// 8. RoomChoice - Nguyện vọng phòng (1-3 nguyện vọng)
model RoomChoice {
  id            Int @id @default(autoincrement())
  applicationId Int @map("application_id")
  roomId        Int @map("room_id")
  priority      Int // 1, 2, 3 (thứ tự ưu tiên)

  application RegistrationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  room        Room                    @relation(fields: [roomId], references: [id])

  @@unique([applicationId, priority]) // Mỗi đơn chỉ có 1 NV1, 1 NV2, 1 NV3
  @@unique([applicationId, roomId]) // Không chọn trùng phòng
  @@map("room_choices")
}

// 9. Contract - Hợp đồng
model Contract {
  id            Int    @id @default(autoincrement())
  code          String @unique // HD-2025-001
  studentId     Int    @map("student_id")
  roomId        Int    @map("room_id")
  bedId         Int?   @map("bed_id") // Chọn khi check-in
  applicationId Int?   @unique @map("application_id")

  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  monthlyRent Decimal  @map("monthly_rent") @db.Decimal(12, 0)

  isRoomLeader      Boolean        @default(false) @map("is_room_leader") // Trưởng phòng
  status            ContractStatus @default(ACTIVE)
  checkedInAt       DateTime?      @map("checked_in_at")
  checkedOutAt      DateTime?      @map("checked_out_at")
  terminationReason String?        @map("termination_reason")

  createdById Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  student     Student                  @relation(fields: [studentId], references: [id])
  room        Room                     @relation(fields: [roomId], references: [id])
  bed         Bed?                     @relation(fields: [bedId], references: [id])
  application RegistrationApplication? @relation(fields: [applicationId], references: [id])
  createdBy   User?                    @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([studentId])
  @@index([roomId])
  @@index([bedId])
  @@index([status])
  @@map("contracts")
}

// 15. PasswordResetToken - Token đặt lại mật khẩu
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// 10. MeterReading - Chỉ số công tơ điện/nước
model MeterReading {
  id           Int       @id @default(autoincrement())
  roomId       Int       @map("room_id")
  meterType    MeterType @map("meter_type")
  readingMonth DateTime  @map("reading_month") @db.Date // Tháng ghi (YYYY-MM-01)

  previousReading Decimal @map("previous_reading") @db.Decimal(12, 2)
  currentReading  Decimal @map("current_reading") @db.Decimal(12, 2)
  consumption     Decimal @db.Decimal(12, 2) // = current - previous

  recordedById Int?     @map("recorded_by")
  recordedAt   DateTime @default(now()) @map("recorded_at")

  room       Room  @relation(fields: [roomId], references: [id])
  recordedBy User? @relation(fields: [recordedById], references: [id])

  @@unique([roomId, meterType, readingMonth])
  @@index([roomId])
  @@index([readingMonth])
  @@map("meter_readings")
}

// 11. Invoice - Hóa đơn (theo phòng, trưởng phòng đóng)
model Invoice {
  id           Int      @id @default(autoincrement())
  code         String   @unique // INV-2025-03-A101
  roomId       Int      @map("room_id")
  billingMonth DateTime @map("billing_month") @db.Date

  // Chi phí
  roomFee        Decimal @map("room_fee") @db.Decimal(12, 0) // Tổng tiền phòng
  electricityFee Decimal @map("electricity_fee") @db.Decimal(12, 0) // Tiền điện
  waterFee       Decimal @map("water_fee") @db.Decimal(12, 0) // Tiền nước
  totalAmount    Decimal @map("total_amount") @db.Decimal(12, 0)

  // Thông tin tiêu thụ
  electricityUsage Decimal @map("electricity_usage") @db.Decimal(12, 2) // kWh
  waterUsage       Decimal @map("water_usage") @db.Decimal(12, 2) // m³
  occupantsCount   Int     @map("occupants_count") // Số người

  // Thanh toán
  dueDate      DateTime      @map("due_date") @db.Date
  status       InvoiceStatus @default(PENDING)
  paymentProof String?       @map("payment_proof") // URL ảnh bill chuyển khoản
  paidAt       DateTime?     @map("paid_at")
  approvedById Int?          @map("approved_by")
  approvedAt   DateTime?     @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  room       Room  @relation(fields: [roomId], references: [id])
  approvedBy User? @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@unique([roomId, billingMonth])
  @@index([roomId])
  @@index([billingMonth])
  @@index([status])
  @@map("invoices")
}

// 12. MaintenanceTicket - Báo sự cố
model MaintenanceTicket {
  id           Int    @id @default(autoincrement())
  code         String @unique // TK-2025-001
  roomId       Int    @map("room_id")
  reportedById Int    @map("reported_by")

  category    TicketCategory
  title       String
  description String?
  images      Json? // URLs ảnh đính kèm

  priority TicketPriority @default(NORMAL)
  status   TicketStatus   @default(NEW)

  handledById     Int?      @map("handled_by")
  handledAt       DateTime? @map("handled_at")
  resolutionNote  String?   @map("resolution_note")
  completedAt     DateTime? @map("completed_at")
  rejectionReason String?   @map("rejection_reason")

  // Đánh giá sau hoàn thành
  rating        Int?
  ratingComment String?   @map("rating_comment")
  ratedAt       DateTime? @map("rated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  room       Room    @relation(fields: [roomId], references: [id])
  reportedBy Student @relation(fields: [reportedById], references: [id])
  handledBy  User?   @relation("HandledBy", fields: [handledById], references: [id])

  @@index([roomId])
  @@index([reportedById])
  @@index([status])
  @@map("maintenance_tickets")
}

// 13. Notification - Thông báo
model Notification {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  title         String
  content       String?
  type          String? // INVOICE, TICKET, REGISTRATION, SYSTEM
  referenceType String?   @map("reference_type") // Invoice, Ticket, Application
  referenceId   Int?      @map("reference_id")
  isRead        Boolean   @default(false) @map("is_read")
  readAt        DateTime? @map("read_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// 14. Setting - Cấu hình hệ thống
model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedById Int?     @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("settings")
}
